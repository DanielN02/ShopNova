#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-push checks..."

# Run TypeScript type checks
echo "📝 Checking TypeScript types..."
cd frontend && npm run type-check
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed. Fix errors before pushing."
  exit 1
fi
cd ..

# Run backend tests
echo "🧪 Running backend tests..."

echo "  → Testing user-order-service..."
cd services/user-order-service && npm test
if [ $? -ne 0 ]; then
  echo "❌ User-order-service tests failed. Fix tests before pushing."
  exit 1
fi
cd ../..

echo "  → Testing product-service..."
cd services/product-service && npm test
if [ $? -ne 0 ]; then
  echo "❌ Product-service tests failed. Fix tests before pushing."
  exit 1
fi
cd ../..

echo "  → Testing notification-service..."
cd services/notification-service && npm test
if [ $? -ne 0 ]; then
  echo "❌ Notification-service tests failed. Fix tests before pushing."
  exit 1
fi
cd ../..

# Run frontend tests
echo "  → Testing frontend..."
cd frontend && npm test
if [ $? -ne 0 ]; then
  echo "❌ Frontend tests failed. Fix tests before pushing."
  exit 1
fi
cd ..

echo "✅ All checks passed! Proceeding with push..."

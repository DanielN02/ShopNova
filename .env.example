# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=shopnova
DB_PASSWORD=your_secure_password_here
DB_NAME=shopnova

# Service Ports
PORT=3001
USER_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
ORDER_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long

# Redis Configuration
REDIS_URL=redis://localhost:6379

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@shopnova.com
EMAIL_FROM_NAME=ShopNova

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3001
VITE_PRODUCT_API_URL=http://localhost:3002
VITE_NOTIFICATION_API_URL=http://localhost:3004

# Environment
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB Configuration (for services that use it)
MONGODB_URI=mongodb://shopnova:your_secure_password_here@localhost:27017/shopnova

# Elasticsearch Configuration (optional)
ELASTICSEARCH_URL=http://localhost:9200

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

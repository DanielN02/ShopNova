{
  "name": "shopnova",
  "version": "1.0.0",
  "description": "ShopNova E-commerce Platform",
  "private": true,
  "workspaces": [
    "frontend",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently -n fe,user-order,prod,notif -c blue,green,yellow,magenta \"npm run dev:frontend\" \"npm run dev:user-order\" \"npm run dev:product\" \"npm run dev:notification\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:user-order": "cd services/user-order-service && npm run dev",
    "dev:product": "cd services/product-service && npm run dev",
    "dev:notification": "cd services/notification-service && npm run dev",
    "dev:backend": "concurrently -n user-order,prod,notif -c green,yellow,magenta \"npm run dev:user-order\" \"npm run dev:product\" \"npm run dev:notification\"",
    "build": "cd frontend && npm run build",
    "test": "concurrently -n user-order,prod,notif \"npm run test:user-order\" \"npm run test:product\" \"npm run test:notification\"",
    "test:user-order": "cd services/user-order-service && npm test",
    "test:product": "cd services/product-service && npm test",
    "test:notification": "cd services/notification-service && npm test",
    "type-check": "cd frontend && npm run type-check",
    "test:ci": "bash scripts/test-ci-locally.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "infra:up": "docker compose up -d postgres mongodb redis rabbitmq",
    "infra:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "typescript": "^5.3.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  }
}
